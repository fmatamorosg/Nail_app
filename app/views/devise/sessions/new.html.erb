<div class="flex min-h-screen w-full items-center justify-center bg-gradient-to-br from-[#0F0B14] via-[#2D1B3D] to-pink-600 px-4 py-12">
  <div class="w-full max-w-sm">
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">Bienvenida</h1>
      <p class="mt-3 text-slate-300">Inicia sesión en Nail Studio</p>
    </header>

    <% if flash[:alert].present? %>
      <div class="mb-5 rounded-xl border border-red-500/40 bg-red-500/20 p-3 text-sm text-red-200" role="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if resource.errors.any? %>
      <div class="mb-5 rounded-xl border border-red-500/40 bg-red-500/20 p-3 text-sm text-red-200" role="alert">
        <ul class="list-inside list-disc space-y-1">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "Email",
              aria: { label: "Email" },
              class: "w-full rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-white placeholder:text-slate-400 backdrop-blur-sm focus:border-pink-400 focus:outline-none focus:ring-1 focus:ring-pink-400" %>
      </div>

      <div>
        <%= f.password_field :password,
              autocomplete: "current-password",
              placeholder: "Contraseña",
              aria: { label: "Contraseña" },
              class: "w-full rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-white placeholder:text-slate-400 backdrop-blur-sm focus:border-pink-400 focus:outline-none focus:ring-1 focus:ring-pink-400" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-white/30 bg-white/10 text-pink-500 focus:ring-pink-400 focus:ring-offset-0" %>
          <%= f.label :remember_me, "Recordarme", class: "text-sm text-slate-300" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Iniciar sesión",
              class: "w-full rounded-xl bg-gradient-to-r from-pink-500 to-violet-500 py-3 text-sm font-semibold text-white shadow-lg shadow-pink-500/30 transition-all hover:from-pink-600 hover:to-violet-600" %>
      </div>
    <% end %>

    <% if devise_mapping.recoverable? %>
      <p class="mt-6 text-center">
        <%= link_to "¿Olvidaste tu contraseña?",
              new_password_path(resource_name),
              class: "text-sm text-slate-400 transition-colors hover:text-white" %>
      </p>
    <% end %>
  </div>
</div>
